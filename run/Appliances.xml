<?xml version="1.0" encoding="UTF-8" standalone="yes"?>
<Appliances xmlns="http://github.com/camueller/SmartApplianceEnabler/v2.0">
    <Appliance id="F-00000001-000000000008-00">
        <!--MqttSwitch topic="cmnd/tasmota/Power" onPayload="ON" offPayload="OFF" statusTopic="stat/tasmota/POWER" statusExtractionRegex="ON">
            <Notifications/>
        </MqttSwitch-->
        <HttpSwitch>
            <HttpWrite url="http://tasmota/cm?cmnd=Power%20On">
                <HttpWriteValue name="On"/>
            </HttpWrite>
            <HttpWrite url="http://tasmota/cm?cmnd=Power%20Off">
                <HttpWriteValue name="Off"/>
            </HttpWrite>
            <HttpRead url="http://tasmota/cm?cmnd=Power">
                <HttpReadValue name="On" extractionRegex=":.ON"/>
            </HttpRead>
        </HttpSwitch>
        <!--MqttElectricityMeter topic="tele/tasmota/SENSOR" name="Energy" contentProtocol="JSON" path="$.ENERGY.Total" timePath="$.Time">
            <Notifications/>
        </MqttElectricityMeter-->
        <HttpElectricityMeter pollInterval="20" contentProtocol="JSON">
            <HttpRead url="http://tasmota/cm?cmnd=Status%208">
                <HttpReadValue name="Energy" path="$.StatusSNS.ENERGY.Total"/>
            </HttpRead>
            <Notifications/>
        </HttpElectricityMeter>
        <Schedule enabled="true">
            <RuntimeRequest min="0" max="300" enabled="true"/>
            <DayTimeframe>
                <Start hour="4" minute="0" second="0"/>
                <End hour="20" minute="0" second="0"/>
            </DayTimeframe>
        </Schedule>
    </Appliance>
    <Connectivity>
        <MqttBroker host="localhost" port="1883"/>
        <ModbusTCP id="modbus" host="raspi2" port="502"/>
        <ModbusTCP id="wallbox" host="wallbox" port="502"/>
    </Connectivity>
</Appliances>
